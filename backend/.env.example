# ─── Server ──────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database (SQL Server) ───────────────────────
DB_HOST=localhost
DB_PORT=1433
DB_NAME=jasper_reports
DB_USER=sa
DB_PASSWORD=your_password_here
DB_ENCRYPT=false          # set to true for Azure SQL
DB_TRUST_CERT=true        # set to false in production with a real cert

# ─── JWT ─────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-key-here-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another-very-long-random-secret-for-refresh-tokens
JWT_REFRESH_EXPIRES_IN=7d

# ─── JasperReports Server ─────────────────────────
JASPER_BASE_URL=http://localhost:8080/jasperserver
JASPER_USERNAME=jasperadmin
JASPER_PASSWORD=jasperadmin

# ─── Frontend ────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
